# Django
SECRET_KEY=change-me-to-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=example.com,www.example.com
ALLOWED_ORIGINS=https://example.com

# Datenbank (Container-intern)
DB_NAME=mitarbeiterapp
DB_USER=mitarbeiter
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$12$replace-with-bcrypt-hash
ADMIN_ROLE=customer_admin
CUSTOMER_KEY=default

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=no-reply@example.com
SMTP_PASSWORD=change-me
SMTP_ENCRYPTION=tls
FROM_EMAIL=no-reply@example.com
FROM_NAME=Mitarbeiter App
RECIPIENT_EMAIL=office@example.com

# Kryptografie/JWT
ENCRYPTION_KEY=change-me-32-plus-characters
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRE_HOURS=8
JWT_COOKIE_NAME=jwt
JWT_COOKIE_SECURE=True

# Spam-Schutz
PDF_API_SECRET=change-me-to-a-long-random-secret
PDF_RATE_LIMIT=10
