{
  "name": "mitarbeiter-pro",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest --coverage",
    "test:manual": "node src/test/manual-test-runner.js",
    "test:all": "npm run test:run && npm run test:manual",
    "i18n:check": "node scripts/validate-i18n.js",
    "i18n:check:strict": "node scripts/validate-i18n.js --strict",
    "i18n:sync": "node scripts/sync-missing-keys.js",
    "i18n:sync:dry": "node scripts/sync-missing-keys.js --dry-run",
    "prebuild": "npm run i18n:check:strict",
    "skill:gate": "node ./scripts/skill-gate-runner.cjs",
    "setup:customer": "node ./scripts/setup-customer.js",
    "customer:create": "node ./scripts/create-customer-profile.js",
    "build:customer": "node ./scripts/build-customer.js",
    "dev:customer": "node ./scripts/dev-customer.js"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.5",
    "@mui/material": "^7.3.5",
    "framer-motion": "^12.23.24",
    "i18next": "^23.7.0",
    "lucide-react": "^0.263.1",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^14.0.0",
    "react-signature-canvas": "^1.1.0-alpha.2"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.9.2",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.16",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^27.1.0",
    "knip": "^5.73.3",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.11",
    "vite-plugin-pwa": "^0.19.8",
    "vitest": "^3.2.4"
  }
}
