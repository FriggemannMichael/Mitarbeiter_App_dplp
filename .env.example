# MitarbeiterApp Pro - Environment Configuration
# ================================================
# Kopieren Sie diese Datei zu ".env" und passen Sie die Werte an Ihre Firma an
# WICHTIG: Die .env Datei NICHT in Git committen!

# ========================================
# API KONFIGURATION
# ========================================

# Backend API URL (für Konfiguration und Datenaustausch)
# Development: http://localhost:5173 (Vite proxy → /backend → localhost:8000)
# Production: https://ihre-domain.de/backend
VITE_API_URL=https://ihre-domain.de/backend

# API erzwingen (auch in Development)
# Standard: false (nutzt in Dev-Mode lokale Konfiguration)
VITE_FORCE_API=false

# ========================================
# SICHERHEIT
# ========================================

# Company Code - Required for app authorization
# Dieser Code muss mit VITE_EXPECTED_CODE übereinstimmen
VITE_COMPANY_CODE=TIMESHEET-PRO-2025
VITE_EXPECTED_CODE=TIMESHEET-PRO-2025

# Admin Password - Required for configuration changes
# WICHTIG: Ändern Sie dieses Passwort zu einem sicheren Wert!
VITE_ADMIN_PASSWORD=IhrSicheresPasswort123!

# ========================================
# FIRMENINFORMATIONEN
# ========================================
# Diese Werte werden als Fallback verwendet wenn die Backend-API
# nicht erreichbar ist oder keine Konfiguration vorhanden ist

# Firmenname (erscheint in der App und auf PDFs)
VITE_COMPANY_NAME=Ihre Firma GmbH

# Vollständige Firmenadresse
VITE_COMPANY_ADDRESS=Musterstraße 1, 12345 Musterstadt

# Firmentelefon (mit Ländercode, z.B. +49 für Deutschland)
VITE_COMPANY_PHONE=+49123456789

# Firmen-E-Mail
VITE_COMPANY_EMAIL=info@ihre-firma.de

# Firmenlogo (optional, Pfad zum Logo in public/ Ordner)
# Beispiel: /assets/logo-firma.png
# Wenn leer, wird kein Logo angezeigt
VITE_COMPANY_LOGO=

# ========================================
# ERLAUBTE KONTAKTE (ANSPRECHPARTNER)
# ========================================
# Nur an diese Kontakte können Stundennachweise versendet werden

# Erlaubte E-Mail-Adressen (kommagetrennt, keine Leerzeichen)
# Nur an diese Adressen können Stundennachweise per E-Mail gesendet werden
VITE_ALLOWED_EMAILS=info@ihre-firma.de,personal@ihre-firma.de,buchhaltung@ihre-firma.de

# Erlaubte WhatsApp-Nummern (kommagetrennt, mit Ländercode, keine Leerzeichen)
# Nur an diese Nummern können Stundennachweise per WhatsApp gesendet werden
VITE_ALLOWED_WHATSAPP=+49123456789,+49987654321

# Standard-E-Mail für automatische Weiterleitung
# Muss in VITE_ALLOWED_EMAILS enthalten sein
VITE_DEFAULT_EMAIL=info@ihre-firma.de

# Standard-WhatsApp für automatische Weiterleitung
# Muss in VITE_ALLOWED_WHATSAPP enthalten sein
VITE_DEFAULT_WHATSAPP=+49123456789

# ========================================
# EXPORT-EINSTELLUNGEN
# ========================================

# Dateiname-Muster für PDF-Exports
# Verfügbare Platzhalter: {employeeName}, {weekYear}, {weekNumber}
VITE_FILENAME_PATTERN=Stundennachweis_{employeeName}_{weekYear}_KW{weekNumber}

# ========================================
# APP-EINSTELLUNGEN
# ========================================

# App Version
VITE_APP_VERSION=1.0.0-beta

# ========================================
# POCKETBASE KONFIGURATION
# ========================================

# PocketBase Server URL
# Development: http://127.0.0.1:8090
# Production: https://api.ihre-domain.de
VITE_POCKETBASE_URL=http://127.0.0.1:8090
